[
//方便阅读
{
    "key": "alt+oem_minus",
    "command": "workbench.action.navigateBack"
},
{
    "key": "alt+oem_plus",
    "command": "workbench.action.navigateForward"
},
{
    "key": "alt+d",
    "command": "workbench.action.navigateForward"
},
{
    "key": "alt+i",
    "command": "cursorUp"
},
{
    "key": "alt+k",
    "command": "cursorDown"
},
{
    "key": "alt+j",
    "command": "cursorLeft"
},
{
    "key": "alt+l",
    "command": "cursorRight"
},
{
    "key": "alt+h",
    "command": "cursorHome"
},
{
    "key": "alt+;",
    "command": "cursorEnd"
},
