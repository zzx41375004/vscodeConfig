// 选中上下左右内容
{
    "key": "shift+alt+i",
    "command": "cursorUpSelect",
    "when": "textInputFocus"
},
{
    "key": "shift+alt+k",
    "command": "cursorDownSelect",
    "when": "textInputFocus"
},
{
    "key": "shift+alt+j",
    "command": "cursorLeftSelect",
    "when": "textInputFocus"
},
{
    "key": "shift+alt+l",
    "command": "cursorRightSelect",
    "when": "textInputFocus"
},
//从当前到行首选中
{
    "key": "shift+alt+h",
    "command": "cursorHomeSelect",
    "when": "textInputFocus"
},
从当前到行尾选中
{
    "key": "shift+alt+;",
    "command": "cursorEndSelect",
    "when": "textInputFocus"
},
